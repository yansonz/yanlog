{
  "enabled": true,
  "name": "이미지 WebP 변환",
  "description": "public/images에 추가된 이미지를 WebP로 자동 변환",
  "version": "1",
  "when": {
    "type": "fileCreated",
    "patterns": [
      "public/images/**/*.jpg",
      "public/images/**/*.jpeg",
      "public/images/**/*.png",
      "public/images/**/*.gif",
      "public/images/**/*.tiff"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "🖼️ 새로운 이미지 파일이 감지되었습니다.\n\nconvert-to-webp 스킬을 사용해서 WebP로 변환해주세요.\n변환 후 원본 파일은 삭제합니다."
  }
}
